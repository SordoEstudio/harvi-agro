---
import data from '../content/howItWorks.json';
---

<section id={data.id} class="scroll-mt-[72px] py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-3xl">
      <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">{data.eyebrow}</span>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
        {data.title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-balance text-[#203143]/80">
        {data.subtitle}
      </p>
    </div>

    <ol class="mt-14 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {data.steps.map((s) => (
        <li class="relative rounded-2xl border border-[#cbdf4a] bg-[#f7f7f7] p-6 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <span class="text-5xl font-extrabold text-[#cbdf4a] leading-none">{s.n}</span>
          <h3 class="mt-4 text-lg font-bold text-[#203143]">{s.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
