---
import data from '../content/about.json';
import CardIcon from '../components/CardIcon.astro';
import VisualFrame from '../components/VisualFrame.astro';
import Icon from '../components/Icon.astro';
import type { IconName } from '../components/LucideIcon';
---

<section id={data.id} class="scroll-mt-[72px] py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid lg:grid-cols-[1fr_auto] gap-10 lg:gap-14 items-center">
      <div class="max-w-3xl">
        <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">
          {data.eyebrow}
        </span>
        <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
          {data.title.lines.map((line, i) => (
            <>
              {line}{i < data.title.lines.length - 1 ? <br /> : null}
            </>
          ))}
        </h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-balance text-[#203143]/85">
          {data.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <figure class="relative mx-auto lg:mx-0 shrink-0 w-full max-w-[280px] md:max-w-[360px]">
        <VisualFrame src={data.image.src} alt={data.image.alt} />
        <div
          class="absolute -bottom-4 -right-4 hidden md:flex items-center gap-2 bg-white rounded-2xl shadow-lg border border-[#cbdf4a] px-3 py-3"
          role="img"
          aria-label={data.imageBadge.label}
        >
          <div
            class="h-10 w-10 rounded-full bg-[#cbdf4a] flex items-center justify-center text-[#203143] shadow-md ring-4 ring-white"
            title={data.imageBadge.label}
          >
            <Icon name={data.imageBadge.icon as IconName} />
            <span class="sr-only">{data.imageBadge.label}</span>
          </div>
        </div>
      </figure>
    </div>

    <ul class="mt-14 md:mt-16 grid md:grid-cols-3 gap-6 md:gap-8 pt-5">
      {data.values.map((v) => (
        <li class="relative group rounded-2xl border border-[#cbdf4a] bg-[#f7f7f7] p-6 pt-10 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <CardIcon>
            <Icon name={v.icon as IconName} />
          </CardIcon>
          <h3 class="text-xl font-bold text-[#203143]">{v.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{v.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
