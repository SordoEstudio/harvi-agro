---
import data from '../content/apertio.json';
import CardIcon from '../components/CardIcon.astro';
import VisualFrame from '../components/VisualFrame.astro';
import Icon from '../components/Icon.astro';
---

<section id={data.id} class="scroll-mt-[72px] py-20 md:py-28 bg-[#103d20] text-white relative overflow-hidden">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-0 opacity-20">
    <div class="absolute -top-20 right-1/4 w-[420px] h-[420px] rounded-full blur-3xl animate-float-medium"
         style="background: var(--harvi-green-lime);"></div>
    <div class="absolute bottom-0 -left-20 w-[360px] h-[360px] rounded-full blur-3xl animate-float-slow"
         style="background: var(--harvi-blue-light);"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4">
    <div class="grid lg:grid-cols-[1fr_auto] gap-10 lg:gap-14 items-center">
      <div class="max-w-3xl">
        <span class="text-sm font-bold uppercase tracking-wider text-[#cbdf4a]">
          {data.eyebrow}
        </span>
        <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-white">
          {data.title.lines.map((line, i) => (
            <>
              {line}{i < data.title.lines.length - 1 ? <br /> : null}
            </>
          ))}
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-balance text-[#c5daf3]">
          {data.subtitle}
        </p>

        <a
          href={data.link.href}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center gap-2 text-[#cbdf4a] font-bold decoration-[#cbdf4a] decoration-2 underline-offset-4 hover:underline"
        >
          {data.link.label}
          <Icon name="arrow-right" size={18} class="shrink-0" />
        </a>
      </div>

      <figure class="relative mx-auto lg:mx-0 shrink-0 w-full max-w-[240px] md:max-w-[300px]">
        <VisualFrame src={data.logo.src} alt={data.logo.alt} />
      </figure>
    </div>

    <ul class="mt-14 grid md:grid-cols-3 gap-6 md:gap-8 pt-5">
      {data.benefits.map((b) => (
        <li class="relative rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm p-6 pt-10 shadow-md">
          <CardIcon ringClass="ring-[#103d20]">
            <Icon name="check" />
          </CardIcon>
          <h3 class="text-lg font-bold text-white">{b.title}</h3>
          <p class="mt-2 text-[#c5daf3] leading-relaxed">{b.body}</p>
        </li>
      ))}
    </ul>

    <div class="mt-14 rounded-2xl bg-[#cbdf4a] text-[#203143] p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 shadow-xl">
      <p class="text-lg md:text-xl font-bold text-balance">
        {data.banner.text}
      </p>
      <a
        href={data.banner.cta.href}
        class="inline-flex items-center justify-center gap-2 rounded-2xl bg-[#203143] text-[#cbdf4a] font-bold px-8 py-4 shadow-md hover:scale-[1.03] hover:shadow-xl transition-all duration-300 ease-out"
      >
        {data.banner.cta.label}
        <Icon name="arrow-right" size={18} class="shrink-0" />
      </a>
    </div>
  </div>
</section>
