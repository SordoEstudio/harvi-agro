---
import data from '../content/audience.json';
import CardIcon from '../components/CardIcon.astro';
import Icon from '../components/Icon.astro';
import type { IconName } from '../components/LucideIcon';
---

<section id={data.id} class="scroll-mt-[72px] py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-3xl">
      <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">{data.eyebrow}</span>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
        {data.title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-balance text-[#203143]/80">
        {data.subtitle}
      </p>
    </div>

    <ul class="mt-14 grid md:grid-cols-3 gap-6 md:gap-8 pt-5">
      {data.roles.map((r) => (
        <li class="relative flex flex-col rounded-2xl border border-[#cbdf4a] bg-[#f7f7f7] p-6 pt-10 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <CardIcon>
            <Icon name={r.icon as IconName} />
          </CardIcon>
          <h3 class="text-xl font-bold text-[#203143]">{r.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{r.desc}</p>
          <ul class="mt-5 space-y-2.5 border-t border-[#cbdf4a]/40 pt-5">
            {r.bullets.map((b) => (
              <li class="flex gap-2 text-sm text-[#203143]/85">
                <Icon name="arrow-right" size={14} class="text-[#103d20] shrink-0 mt-0.5" strokeWidth={2.5} />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</section>
