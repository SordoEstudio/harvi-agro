---
const roles = [
  {
    emoji: '🚜',
    title: 'Contratista de aplicación',
    desc: 'Prestás servicios con tus máquinas y necesitás demostrar que trabajaste bien. Harvi Agro te da el respaldo técnico para cada trabajo.',
    bullets: [
      'Mostrá el reporte al productor antes de salir del campo',
      'Detectá solapamientos antes de que te los reclamen',
      'Guardá el historial de todos tus trabajos por cliente',
    ],
  },
  {
    emoji: '📋',
    title: 'Agrónomo asesor',
    desc: 'Hacés la prescripción y después necesitás verificar que se cumplió. Sin herramientas, ese control queda en el olvido.',
    bullets: [
      'Compará prescripción vs ejecución zona por zona',
      'Generá el informe de cumplimiento para tus registros técnicos',
      'Detectá qué contratistas trabajan con más precisión',
    ],
  },
  {
    emoji: '🌾',
    title: 'Productor',
    desc: 'Contratás servicios o tenés equipos propios. Querés saber que los insumos se aplicaron como correspondía, sin tener que estar en el campo.',
    bullets: [
      'Recibí el informe del trabajo en tu celular',
      'Controlá el uso de insumos en todos tus lotes',
      'Tenés el historial completo de la temporada',
    ],
  },
];
---

<section id="para-quien" class="scroll-mt-[72px] py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-3xl">
      <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">Usuarios</span>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
        ¿Para quién es Harvi Agro?
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-balance text-[#203143]/80">
        Tres perfiles distintos, una sola herramienta que se adapta
        a lo que cada uno necesita ver.
      </p>
    </div>

    <ul class="mt-14 grid md:grid-cols-3 gap-6">
      {roles.map((r) => (
        <li class="flex flex-col rounded-2xl border border-[#cbdf4a] bg-[#f7f7f7] p-6 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <div class="h-14 w-14 rounded-full bg-[#cbdf4a] flex items-center justify-center text-2xl shadow-md ring-4 ring-white">
            <span aria-hidden="true">{r.emoji}</span>
          </div>
          <h3 class="mt-5 text-xl font-bold text-[#203143]">{r.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{r.desc}</p>
          <ul class="mt-5 space-y-2.5 border-t border-[#cbdf4a]/40 pt-5">
            {r.bullets.map((b) => (
              <li class="flex gap-2 text-sm text-[#203143]/85">
                <span class="text-[#103d20] font-bold" aria-hidden="true">→</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</section>
