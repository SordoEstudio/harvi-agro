---
const features = [
  {
    icon: 'map',
    title: 'Mapa del trabajo',
    desc: 'Visualizá cada pasada sobre imagen satelital. Coloreado automático por velocidad, dosis aplicada o desvío de prescripción.',
    plan: 'Incluido (free)',
  },
  {
    icon: 'layers',
    title: 'Detección de solapamientos',
    desc: 'Calcula automáticamente las zonas de doble aplicación: área en hectáreas y kilos estimados de producto gastado de más.',
    plan: 'Incluido (free)',
  },
  {
    icon: 'compare',
    title: 'Prescripción vs Realidad',
    desc: 'Compará lo que indicó el agrónomo con lo que ejecutó la máquina. Zona por zona, con porcentaje de cumplimiento.',
    plan: 'Incluido (free)',
  },
  {
    icon: 'chart',
    title: 'Estadísticas completas',
    desc: 'Velocidad mínima, promedio y máxima. Dosis real vs recomendada. Histogramas de distribución. Todo en una pantalla.',
    plan: 'Incluido (free)',
  },
  {
    icon: 'pdf',
    title: 'Informe PDF técnico',
    desc: 'Generá un reporte listo para entregar al productor: mapas, estadísticas y resumen ejecutivo. Con logo de tu empresa.',
    plan: 'Plan Pro',
  },
  {
    icon: 'history',
    title: 'Historial de campaña',
    desc: 'Guardá todos los trabajos de la temporada y comparalos. Detectá patrones, equipos con desvíos y zonas problemáticas.',
    plan: 'Plan Pro',
  },
];
---

<section id="producto" class="scroll-mt-[72px] py-20 md:py-28 bg-[#f7f7f7]">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-3xl">
      <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">La plataforma</span>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
        Todo lo que necesitás<br />para analizar un trabajo.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-balance text-[#203143]/80">
        Subís el archivo de la pantalla, la plataforma lo procesa y en minutos tenés
        un análisis completo. Sin instalaciones, sin configuración, desde cualquier dispositivo.
      </p>
    </div>

    <ul class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <li class="group flex flex-col rounded-2xl border border-[#cbdf4a] bg-white p-6 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <div class="flex items-center justify-between">
            <div class="h-12 w-12 rounded-full bg-[#cbdf4a] flex items-center justify-center text-[#203143] shadow-md ring-4 ring-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
                {f.icon === 'map' && (
                  <>
                    <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                    <line x1="8" y1="2" x2="8" y2="18" />
                    <line x1="16" y1="6" x2="16" y2="22" />
                  </>
                )}
                {f.icon === 'layers' && (
                  <>
                    <polygon points="12 2 2 7 12 12 22 7 12 2" />
                    <polyline points="2 17 12 22 22 17" />
                    <polyline points="2 12 12 17 22 12" />
                  </>
                )}
                {f.icon === 'compare' && (
                  <>
                    <path d="M16 3l4 4-4 4" />
                    <path d="M20 7H4" />
                    <path d="M8 21l-4-4 4-4" />
                    <path d="M4 17h16" />
                  </>
                )}
                {f.icon === 'chart' && (
                  <>
                    <line x1="3" y1="20" x2="21" y2="20" />
                    <rect x="5" y="10" width="3" height="10" />
                    <rect x="10.5" y="6" width="3" height="14" />
                    <rect x="16" y="13" width="3" height="7" />
                  </>
                )}
                {f.icon === 'pdf' && (
                  <>
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="9" y1="15" x2="15" y2="15" />
                    <line x1="9" y1="18" x2="13" y2="18" />
                  </>
                )}
                {f.icon === 'history' && (
                  <>
                    <path d="M3 12a9 9 0 1 0 3-6.7L3 8" />
                    <polyline points="3 3 3 8 8 8" />
                    <polyline points="12 7 12 12 15 14" />
                  </>
                )}
              </svg>
            </div>
            <span class={`text-xs font-bold rounded-full px-3 py-1 ${f.plan === 'Plan Pro' ? 'bg-[#203143] text-[#cbdf4a]' : 'bg-[#cbdf4a]/30 text-[#103d20]'}`}>
              {f.plan}
            </span>
          </div>
          <h3 class="mt-5 text-xl font-bold text-[#203143]">{f.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{f.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
