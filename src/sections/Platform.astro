---
import data from '../content/platform.json';
import CardIcon from '../components/CardIcon.astro';
import VisualFrame from '../components/VisualFrame.astro';
import Icon from '../components/Icon.astro';
import type { IconName } from '../components/LucideIcon';
---

<section id={data.id} class="scroll-mt-[72px] py-20 md:py-28 bg-[#f7f7f7]">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid lg:grid-cols-[1fr_1.15fr] gap-10 lg:gap-14 items-center">
      <div class="max-w-3xl">
        <span class="text-sm font-bold uppercase tracking-wider text-[#103d20]">{data.eyebrow}</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-bold text-balance text-[#203143]">
          {data.title.lines.map((line, i) => (
            <>
              {line}{i < data.title.lines.length - 1 ? <br /> : null}
            </>
          ))}
        </h2>
        {data.paragraphs.map((p, i) => (
          <p class={`${i === 0 ? 'mt-6' : 'mt-4'} text-lg leading-relaxed text-balance text-[#203143]/80`}>
            {p}
          </p>
        ))}

        <a
          href={data.cta.href}
          target="_blank"
          rel="noopener"
          class="mt-8 inline-flex items-center justify-center gap-2 rounded-2xl bg-[#cbdf4a] border border-[#cbdf4a] text-[#203143] font-bold px-8 py-4 shadow-md hover:scale-[1.03] hover:shadow-xl transition-all duration-300 ease-out"
        >
          {data.cta.label}
          <Icon name="arrow-right" size={18} class="shrink-0" />
        </a>
      </div>

      <figure class="relative mx-auto lg:mx-0 w-full max-w-[520px] lg:max-w-none">
        <VisualFrame src={data.image.src} alt={data.image.alt} />
      </figure>
    </div>

    <ul class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 pt-5">
      {data.features.map((f) => (
        <li class="relative group flex flex-col rounded-2xl border border-[#cbdf4a] bg-white p-6 pt-10 shadow-md hover:scale-[1.02] hover:shadow-xl transition-all duration-300 ease-out">
          <CardIcon>
            <Icon name={f.icon as IconName} />
          </CardIcon>
          <h3 class="text-xl font-bold text-[#203143]">{f.title}</h3>
          <p class="mt-2 text-[#203143]/80 leading-relaxed">{f.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
