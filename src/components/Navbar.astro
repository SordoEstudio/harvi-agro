---
import data from '../content/navbar.json';

const waHref = `https://wa.me/${data.contact.whatsappPhone}?text=${encodeURIComponent(data.contact.whatsappText)}`;
---

<header class="fixed top-0 inset-x-0 z-40 bg-white shadow-sm">
  <nav class="mx-auto max-w-6xl px-4 h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img
        src={data.logo.src}
        alt={data.logo.alt}
        class="h-8 md:h-9 w-auto"
        loading="eager"
        decoding="async"
      />
      <span class="text-xl font-normal tracking-tight text-[#203143] lowercase">{data.logo.suffix}</span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {data.links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-bold text-[#203143] hover:text-[#cbdf4a] transition-colors duration-300 ease-out"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={waHref}
      target="_blank"
      rel="noopener"
      class="text-sm font-bold text-[#203143] hover:text-[#cbdf4a] transition-colors duration-300 ease-out"
    >
      {data.contact.label}
    </a>
  </nav>
</header>
