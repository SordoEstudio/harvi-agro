---
const navLinks = [
  { href: '#producto', label: 'Plataforma' },
  { href: '#para-quien', label: 'Para quién' },
  { href: '#apertio', label: 'Apertio' },
];
---

<header class="fixed top-0 inset-x-0 z-40 bg-white shadow-sm">
  <nav class="mx-auto max-w-6xl px-4 h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-baseline gap-2">
      <span class="text-xl font-extrabold tracking-tight text-[#203143]">Harvi Agro</span>
      <span class="hidden sm:inline text-xs font-medium text-[#203143]/60">by Harvestech</span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-bold text-[#203143] hover:text-[#cbdf4a] transition-colors duration-300 ease-out"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="https://apertio.harviagro.digital"
      class="inline-flex items-center gap-2 rounded-2xl bg-[#cbdf4a] border border-[#cbdf4a] text-[#203143] font-bold px-5 py-2.5 text-sm shadow-md hover:scale-[1.03] hover:shadow-xl transition-all duration-300 ease-out"
    >
      Empezar gratis
      <span aria-hidden="true">→</span>
    </a>
  </nav>
</header>
