---
import data from '../content/navbar.json';
---

<header class="fixed top-0 inset-x-0 z-40 bg-white shadow-sm">
  <nav class="mx-auto max-w-6xl px-4 h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img
        src={data.logo.src}
        alt={data.logo.alt}
        class="h-8 md:h-9 w-auto"
        loading="eager"
        decoding="async"
      />
      <span class="text-xl font-normal tracking-tight text-[#203143] lowercase">{data.logo.suffix}</span>
    </a>

    <a
      href={data.cta.href}
      class="inline-flex items-center justify-center rounded-2xl bg-[#cbdf4a] border border-[#cbdf4a] text-[#203143] text-sm font-bold px-5 py-2.5 md:px-6 md:py-3 shadow-md hover:scale-[1.03] hover:shadow-xl transition-all duration-300 ease-out"
    >
      {data.cta.label}
    </a>
  </nav>
</header>
