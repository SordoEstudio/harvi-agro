---
import { LucideIcon } from './LucideIcon';
import type { IconName } from './LucideIcon';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 18, class: className, strokeWidth } = Astro.props;
---

<LucideIcon name={name} size={size} className={className} strokeWidth={strokeWidth} />
