---
import data from '../content/footer.json';
import { InstagramIcon } from './InstagramIcon';

const year = new Date().getFullYear();
const { copyright, instagram } = data;
---

<footer class="border-t border-[#0a2815] bg-[#103d20]">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="relative flex w-full flex-col gap-6 md:min-h-[4.5rem]">
      <div class="text-center text-sm leading-relaxed text-[#c5daf3]/90 md:absolute md:left-1/2 md:top-1/2 md:z-0 md:w-full md:max-w-md md:-translate-x-1/2 md:-translate-y-1/2 md:px-4">
        <p>
          © {year} {copyright.brand} desarrollado por{' '}
          <a
            href={copyright.developedBy.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#c5daf3] no-underline transition hover:text-white hover:underline hover:underline-offset-2"
          >
            {copyright.developedBy.label}
          </a>
        </p>
        <p class="mt-1">{copyright.rights}</p>
      </div>

      <div class="flex justify-center md:absolute md:left-0 md:top-1/2 md:z-10 md:-translate-y-1/2 md:justify-start">
        <a
          href={instagram.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex flex-wrap items-center justify-center gap-2 text-[#c5daf3] transition hover:text-white md:justify-start"
        >
          <span class="text-sm font-semibold">{instagram.follow_label}</span>
          <InstagramIcon className="h-6 w-6 shrink-0" />
          <span class="text-sm font-semibold">{instagram.handle}</span>
        </a>
      </div>
    </div>
  </div>
</footer>
