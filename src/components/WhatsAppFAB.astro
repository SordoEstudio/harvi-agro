---
import data from '../content/whatsapp.json';
import { WhatsAppIcon } from './WhatsAppIcon';

const waHref = `https://wa.me/${data.phone}?text=${encodeURIComponent(data.text)}`;
---

<a
  href={waHref}
  target="_blank"
  rel="noopener"
  aria-label={data.ariaLabel}
  class="fixed bottom-6 right-6 z-50 flex items-center justify-center h-[4.25rem] w-[4.25rem] rounded-full bg-[#cbdf4a] text-[#203143] shadow-xl ring-4 ring-white hover:scale-[1.05] transition-all duration-300 ease-out"
>
  <WhatsAppIcon size={32} />
</a>
